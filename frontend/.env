# Frontend environment variables — DEMO VERSION
# ─────────────────────────────────────────────────────────────────────────────
# This demo version works WITHOUT a backend server.
# All data is stored in your browser's localStorage.
# No VITE_API_URL is needed for the demo.

# If you want to connect to a real backend instead:
# VITE_API_URL=http://localhost:4000
